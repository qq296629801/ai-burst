<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiburst.mag.mapper.MagAlertEventMapper">

    <resultMap id="BaseMap" type="com.aiburst.mag.entity.MagAlertEvent">
        <id column="id" property="id"/>
        <result column="project_id" property="projectId"/>
        <result column="task_id" property="taskId"/>
        <result column="alert_type" property="alertType"/>
        <result column="level" property="level"/>
        <result column="payload_json" property="payloadJson"/>
        <result column="acknowledged" property="acknowledged"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mag_alert_event (project_id, task_id, alert_type, level, payload_json, acknowledged)
        VALUES (#{projectId}, #{taskId}, #{alertType}, #{level}, #{payloadJson}, #{acknowledged})
    </insert>

    <select id="selectByProjectId" resultMap="BaseMap">
        SELECT * FROM mag_alert_event WHERE project_id = #{projectId} ORDER BY id DESC
    </select>

    <select id="selectById" resultMap="BaseMap">SELECT * FROM mag_alert_event WHERE id = #{id}</select>

    <update id="updateAcknowledged">UPDATE mag_alert_event SET acknowledged = #{acknowledged} WHERE id = #{id}</update>
</mapper>
