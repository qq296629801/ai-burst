<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiburst.mag.mapper.MagRequirementRevisionMapper">

    <resultMap id="BaseMap" type="com.aiburst.mag.entity.MagRequirementRevision">
        <id column="id" property="id"/>
        <result column="doc_id" property="docId"/>
        <result column="version" property="version"/>
        <result column="content" property="content"/>
        <result column="author_user_id" property="authorUserId"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mag_requirement_revision (doc_id, version, content, author_user_id)
        VALUES (#{docId}, #{version}, #{content}, #{authorUserId})
    </insert>

    <select id="selectLatest" resultMap="BaseMap">
        SELECT * FROM mag_requirement_revision WHERE doc_id = #{docId} ORDER BY version DESC LIMIT 1
    </select>

    <select id="selectByDocAndVersion" resultMap="BaseMap">
        SELECT * FROM mag_requirement_revision WHERE doc_id = #{docId} AND version = #{version} LIMIT 1
    </select>

    <select id="selectById" resultMap="BaseMap">
        SELECT * FROM mag_requirement_revision WHERE id = #{id}
    </select>

    <select id="listByDocId" resultMap="BaseMap">
        SELECT * FROM mag_requirement_revision WHERE doc_id = #{docId} ORDER BY version DESC
    </select>
</mapper>
