<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiburst.mag.mapper.MagThreadMapper">

    <resultMap id="BaseMap" type="com.aiburst.mag.entity.MagThread">
        <id column="id" property="id"/>
        <result column="project_id" property="projectId"/>
        <result column="task_id" property="taskId"/>
        <result column="title" property="title"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mag_thread (project_id, task_id, title) VALUES (#{projectId}, #{taskId}, #{title})
    </insert>

    <select id="selectById" resultMap="BaseMap">SELECT * FROM mag_thread WHERE id = #{id}</select>

    <select id="selectByProjectId" resultMap="BaseMap">
        SELECT * FROM mag_thread WHERE project_id = #{projectId} ORDER BY id DESC
    </select>

    <select id="selectLatestMessageAtByProjectId" resultType="java.time.LocalDateTime">
        SELECT MAX(m.created_at) FROM mag_message m
        INNER JOIN mag_thread t ON m.thread_id = t.id
        WHERE t.project_id = #{projectId}
    </select>
</mapper>
