<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiburst.mapper.RoleMapper">

    <resultMap id="BaseMap" type="com.aiburst.entity.SysRole">
        <id column="id" property="id"/>
        <result column="role_code" property="roleCode"/>
        <result column="role_name" property="roleName"/>
        <result column="remark" property="remark"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="Role_Column_List">
        id, role_code, role_name, remark, created_at
    </sql>

    <select id="selectAll" resultMap="BaseMap">
        SELECT
        <include refid="Role_Column_List"/>
        FROM sys_role
        ORDER BY id
    </select>

    <select id="selectById" resultMap="BaseMap">
        SELECT
        <include refid="Role_Column_List"/>
        FROM sys_role
        WHERE id = #{id}
    </select>

    <select id="countByCode" resultType="int">
        SELECT COUNT(1) FROM sys_role
        WHERE role_code = #{roleCode}
        <if test="excludeId != null">
            AND id != #{excludeId}
        </if>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_role (role_code, role_name, remark)
        VALUES (#{roleCode}, #{roleName}, #{remark})
    </insert>

    <update id="update">
        UPDATE sys_role
        SET role_code = #{roleCode}, role_name = #{roleName}, remark = #{remark}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_role WHERE id = #{id}
    </delete>

    <delete id="deleteRolePermissions">
        DELETE FROM sys_role_permission WHERE role_id = #{roleId}
    </delete>

    <delete id="deletePermissionLinksByPermId">
        DELETE FROM sys_role_permission WHERE perm_id = #{permId}
    </delete>

    <insert id="insertRolePermission">
        INSERT INTO sys_role_permission (role_id, perm_id) VALUES (#{roleId}, #{permId})
    </insert>

    <select id="selectPermissionIdsByRoleId" resultType="long">
        SELECT perm_id FROM sys_role_permission WHERE role_id = #{roleId}
    </select>
</mapper>
